# =============================
# Mailwise Environment Variables
# =============================
# Copy this file to .env.local and fill in all values

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here   # generate with: openssl rand -base64 32

# Google OAuth (for Gmail + sign in)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase
# Get from: https://app.supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email delivery)
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# OpenAI (for AI summaries)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# PayPal
# Client ID (backend REST API): AV3xsoj4EKzYLuycyCuWfu2YyqORgCmYIyW2YZlZLt1VrZ--PqYMjl8VbwGL3D84-ti5w8XHZuwLFiVy
PAYPAL_CLIENT_ID=AV3xsoj4EKzYLuycyCuWfu2YyqORgCmYIyW2YZlZLt1VrZ--PqYMjl8VbwGL3D84-ti5w8XHZuwLFiVy
